            _sl(ar: 'الكاشير', en: 'Cashier', hi: 'कैशियर', ur: 'کیشیئر', es: 'Cajero', tr: 'Kasiyer'),
            data!.cashierName?.isNotEmpty == true
                ? data!.cashierName!
