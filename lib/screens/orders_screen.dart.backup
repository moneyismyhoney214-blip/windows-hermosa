                    ),
                  ),
                ),
              ],
            ),
            const SizedBox(height: 12),
            if (booking.tableName != null)
              Row(
                children: [
                  Icon(LucideIcons.layoutGrid,
                      size: 16, color: Colors.grey.shade500),
                  const SizedBox(width: 4),
