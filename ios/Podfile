# Hermosa POS — iOS Podfile
#
# Mirrors the conventions of a stock `flutter create` Podfile, with two
# additions specific to this app:
#   1. Deployment target pinned to iOS 13.0 (matches IPHONEOS_DEPLOYMENT_TARGET
#      already set in project.pbxproj). Several plugins (`bonsoir_darwin`,
#      `webview_flutter_wkwebview`, `nfc_manager`, `mobile_scanner`) require
#      iOS 12+/13+; pin once here so we don't get a CocoaPods warning per pod.
#   2. `permission_handler` preprocessor macros — when the app is built,
#      ONLY the permissions actually used should be compiled into the
#      permission_handler plugin. Disabled permissions get stubbed out so
#      App Store Review doesn't flag the binary for "unused" capabilities.
#      See: https://pub.dev/packages/permission_handler#ios

# Uncomment this line to define a global platform for your project
platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      # Pin every pod to iOS 13.0 — overrides any pod that ships with an
      # older default and silences "is set to deployment target X" warnings.
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'

      # Drop armv7 / i386 — these are no longer supported by Xcode 14+.
      config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'i386 arm64'

      # ----------------------------------------------------------------
      # permission_handler macros
      #
      # Strip unused permission code paths from the iOS binary. Apple
      # rejects apps whose binary advertises capabilities (location,
      # health, contacts, calendar, reminders, motion, speech, mediaLibrary,
      # sensors, app-tracking, criticalAlerts) when the app does not
      # legitimately need them — even if no usage description is present.
      #
      # Hermosa uses ONLY: camera, bluetooth, photos (read+add), microphone
      # (sound playback fallback). Everything else is disabled below by
      # setting the macro to 0.
      # ----------------------------------------------------------------
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',

        # Enabled — actually used by Hermosa
        'PERMISSION_CAMERA=1',
        'PERMISSION_BLUETOOTH=1',
        'PERMISSION_PHOTOS=1',
        'PERMISSION_PHOTOS_ADD_ONLY=1',
        'PERMISSION_MICROPHONE=1',

        # Disabled — not used; stripped from binary so Apple does not
        # flag the app for declaring capabilities it doesn't exercise.
        'PERMISSION_EVENTS=0',
        'PERMISSION_EVENTS_FULL_ACCESS=0',
        'PERMISSION_REMINDERS=0',
        'PERMISSION_CONTACTS=0',
        'PERMISSION_SPEECH_RECOGNIZER=0',
        'PERMISSION_LOCATION=0',
        'PERMISSION_LOCATION_WHENINUSE=0',
        'PERMISSION_NOTIFICATIONS=0',
        'PERMISSION_MEDIA_LIBRARY=0',
        'PERMISSION_SENSORS=0',
        'PERMISSION_APP_TRACKING_TRANSPARENCY=0',
        'PERMISSION_CRITICAL_ALERTS=0',
        'PERMISSION_ASSISTANT=0',
      ]
    end
  end
end
